# ============================================
# Discord AI Agent 環境變數設定
# ============================================

# AI Provider 設定
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o

# Database 設定
DATABASE_URL=sqlite+aiosqlite:///data/agent.db
# PostgreSQL 範例:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/agent

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# Dashboard (未來啟用)
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8080
